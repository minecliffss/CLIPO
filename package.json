{
  "name": "lensora-gallery-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:python": "cd backend && pip install -r requirements.txt",
    "install:all": "npm run install:python && cd frontend && npm install",
    "dev": "concurrently \"bash backend/start.sh\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "start:backend": "bash backend/start.sh",
    "start:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
